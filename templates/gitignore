# Project .gitignore — installed by research-claude apply.sh.
# Source of truth is the single-file manuscript_<project>.qmd (kept). Generated
# output and large/re-acquirable inputs are ignored.

# ── Quarto / render build artifacts (regenerable from the .qmd) ──────────────
.quarto/
*_files/
*_cache/
/_freeze/

# Rendered manuscript output — render locally or in CI; don't version it.
manuscript_*.pdf
manuscript_*.html
manuscript_*.docx
manuscript_*.tex

# LaTeX intermediates
*.aux
*.log
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.run.xml
*.toc
*.out
*.synctex.gz

# ── Data ─────────────────────────────────────────────────────────────────────
# Raw inputs are large / re-acquirable: ignore everything under data/raw/ but
# keep the provenance manifest and hash-freeze record so inputs stay auditable.
data/raw/**
!data/raw/data_manifest.md
!data/raw/MANIFEST.sha256
# Cleaned/derived data is regenerated by the pipeline.
data/cleaned/

# ── Language toolchain outputs ───────────────────────────────────────────────
# R
*.Rds
*.rds
*.RData
*.rda
.Rhistory
.Rproj.user/
# Python
__pycache__/
*.pyc
*.egg-info/
.venv/
.ipynb_checkpoints/

# ── Local-only Claude state (machine-specific paths stay out of git) ─────────
.claude/state/obsidian-config.md

# ── Editor / OS ──────────────────────────────────────────────────────────────
.DS_Store
